#!/usr/bin/env python3
# -*- mode: python -*-
import sys
import json
import urllib.request

def fetch_markdown(repo, issue_id):
    base_url = f"https://api.github.com/repos/{repo}/issues/{issue_id}"
    headers = {"Accept": "application/vnd.github.v3.raw"}

    def get_url(url):
        req = urllib.request.Request(url, headers=headers)
        with urllib.request.urlopen(req) as response:
            return json.loads(response.read().decode())

    try:
        # 1. Fetch main issue
        issue = get_url(base_url)
        print(f"# {issue.get('title', 'Issue ' + issue_id)}")
        print(f"\n{issue.get('body', '')}")
        print("\n" + "="*40 + "\n")

        # 2. Fetch comments
        comments = get_url(f"{base_url}/comments")
        for i, comment in enumerate(comments, 1):
            user = comment.get('user', {}).get('login', 'unknown')
            print(f"## Comment {i} by @{user}")
            print(f"\n{comment.get('body', '')}")
            print("\n---\n")

    except Exception as e:
        print(f"Error: {e}", file=sys.stderr)
        sys.exit(1)

if __name__ == "__main__":
    if len(sys.argv) != 3:
        print("Usage: ./gh-md.py org/repo issue_number")
    else:
        fetch_markdown(sys.argv[1], sys.argv[2])
